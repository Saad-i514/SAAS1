# Database Configuration
DATABASE_URL="postgresql://user:password@host:port/database"

# Security - REQUIRED: Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY="your-secret-key-here"

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS="https://yourdomain.com,http://localhost:5173"

# Optional: Token expiration in minutes (default: 480 = 8 hours)
# ACCESS_TOKEN_EXPIRE_MINUTES=480
